# ===========================================
# waBaileys — WhatsApp Baileys Alert Bot
# ===========================================
# Copy file ini ke .env dan isi konfigurasi
# cp .env.example .env

# ── WAJIB ──────────────────────────────────
# API Key untuk mengamankan semua endpoint
# Gunakan string acak minimal 16 karakter
# Contoh: openssl rand -hex 32
API_KEY=ubah_dengan_string_acak_32_karakter

# ── OPSIONAL ───────────────────────────────
# Port server (default: 3000)
# PORT=3000

# Level logging: info | debug | warn | error
# LOG_LEVEL=info

# Direktori penyimpanan auth session (default: /app/auth_info)
# AUTH_DIR=/app/auth_info

# Paksa API_KEY harus diisi — server TIDAK AKAN START jika kosong
# Set ke 'false' untuk development (TIDAK DIREKOMENDASIKAN di production)
# REQUIRE_API_KEY=true

# CORS origin yang diizinkan
# '*' = semua origin (mudah untuk dev, tapi tidak aman untuk production)
# Atau set ke domain spesifik: https://dashboard.example.com
# Untuk multiple origin, pisahkan dengan koma: https://app1.com,https://app2.com
# CORS_ORIGIN=*

# Trust proxy — untuk mendapatkan IP asli client di belakang reverse proxy
# Set ke 'true' atau jumlah hop (1, 2, dst)
# TRUST_PROXY=

# Timezone container (default: Asia/Jakarta)
# TZ=Asia/Jakarta

# ── USER PROFILE ──────────────────────────
# Username untuk login dashboard (default: admin)
# DEFAULT_USERNAME=admin

# Password untuk login dashboard
# WAJIB diisi! Jika kosong, fallback menggunakan API_KEY sebagai password
DEFAULT_PASSWORD=ubah_dengan_password_kuat

# Nama tampilan default (bisa diubah dari menu Settings dashboard)
# DISPLAY_NAME=WhatsApp Bot
